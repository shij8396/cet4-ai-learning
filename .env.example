# CET4 AI Learning - Environment Variables
# Copy this file to .env.local for local development.
# Do not commit .env, .env.local, or production secrets.

# Database
# Enterprise default: PostgreSQL. Start locally with `docker compose up -d db`.
DATABASE_URL="postgresql://postgres:password@localhost:5432/cet4_learning"

# Authentication
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
ADMIN_USER_IDS=""

# AI Provider
# AI features degrade gracefully when no API key is configured.
AI_DEFAULT_PROVIDER="openai"
AI_DEFAULT_MODEL="gpt-4o-mini"
OPENAI_API_KEY=""
GEMINI_API_KEY=""
OPENROUTER_API_KEY=""

# AI Rate Limiting
AI_RATE_LIMIT_PER_HOUR="20"
AI_RATE_LIMIT_PER_DAY="100"

# Application
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="CET4 AI Learning"

# Feature Flags
NEXT_PUBLIC_ENABLE_PWA="true"
NEXT_PUBLIC_ENABLE_AI_COACH="true"
NEXT_PUBLIC_ENABLE_DICTATION="true"
NEXT_PUBLIC_ENABLE_WRITING="true"
NEXT_PUBLIC_ENABLE_READING="true"
