# CET4 AI Learning - Environment Variables
# Copy this file to .env.local for local development.
# Do not commit .env, .env.local, or production secrets.

# Database
# The current local app uses Prisma + SQLite through @prisma/adapter-better-sqlite3.
DATABASE_URL="file:./dev.db"

# Authentication
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"

# AI Provider
# AI features degrade gracefully when no API key is configured.
AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Optional Azure OpenAI
# AZURE_OPENAI_API_KEY=""
# AZURE_OPENAI_ENDPOINT=""
# AZURE_OPENAI_DEPLOYMENT=""

# Optional Anthropic
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-3-haiku-20240307"

# AI Rate Limiting
AI_RATE_LIMIT_PER_HOUR="20"
AI_RATE_LIMIT_PER_DAY="100"

# Application
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="CET4 AI Learning"

# Feature Flags
NEXT_PUBLIC_ENABLE_PWA="true"
NEXT_PUBLIC_ENABLE_AI_COACH="true"
NEXT_PUBLIC_ENABLE_DICTATION="true"
NEXT_PUBLIC_ENABLE_WRITING="true"
NEXT_PUBLIC_ENABLE_READING="true"
