# Production Environment Variables Template
# DO NOT commit actual values.

NODE_ENV="production"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="https://your-domain.com"
ADMIN_USER_IDS=""

NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_APP_NAME="CET4 AI Learning"
NEXT_PUBLIC_ENABLE_PWA="true"
NEXT_PUBLIC_ENABLE_AI_COACH="true"
NEXT_PUBLIC_ENABLE_DICTATION="true"
NEXT_PUBLIC_ENABLE_WRITING="true"
NEXT_PUBLIC_ENABLE_READING="true"

AI_DEFAULT_PROVIDER="openai"
AI_DEFAULT_MODEL="gpt-4o-mini"
OPENAI_API_KEY=""
GEMINI_API_KEY=""
OPENROUTER_API_KEY=""
AI_RATE_LIMIT_PER_HOUR="20"
AI_RATE_LIMIT_PER_DAY="100"
