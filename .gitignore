# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# generated PWA assets
/public/sw.js
/public/workbox-*.js
/public/fallback-*.js

# GitHub Actions workflows need a token with workflow scope to publish.
/.github/workflows/e2e-tests.yml

# e2e testing
/test-results/
/playwright-report/
/.playwright-cli/
/tests/e2e/.auth/
/tests/e2e/fixtures/.auth/

# local data and reports
/dev.db
*.db
*.db-journal
*.sqlite
*.sqlite-journal
dev-server*.log
doctor-report.md
